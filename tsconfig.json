{
    "compilerOptions": {
        /* Core */
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "jsx": "preserve",
        "jsxImportSource": "vue",
        "resolveJsonModule": true,
        "noEmit": true,

        /* TypeScript behavior */
        "strict": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,

        /* Path aliases */
        "paths": {
            "@/*": ["./resources/js/*"],
            "ziggy-js": ["./vendor/tightenco/ziggy"],
            "@wangeditor/editor-for-vue": [
                "./node_modules/@wangeditor/editor-for-vue/dist/src/index.d.ts"
            ]
        },

        /* Type roots */
        "types": ["vite/client", "vue/tsx", "./resources/js/types"]
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts",
        "resources/js/**/*.tsx",
        "resources/js/**/*.vue",
        "resources/js/types/components.d.ts"
    ]
}
