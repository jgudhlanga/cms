APP_NAME=HREPOLY
APP_DISPLAY_NAME="Harare Polytechnic"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://hrepoly.test

# Disable Boost browser log uploads locally to avoid 413 errors on large console payloads.
# BOOST_BROWSER_LOGS_WATCHER=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hrepoly
DB_USERNAME=root
DB_PASSWORD=

LEGACY_DB_HOST=
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=
LEGACY_DB_USERNAME=
LEGACY_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Matches Str::slug(APP_NAME, '_').'_session' when APP_NAME=HREPOLY
SESSION_COOKIE=hrepoly_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# Laravel 13 skeleton uses hyphenated default prefixes. This repo’s config still uses
# Str::slug(APP_NAME, '_') fallbacks; pin these if you sync stubs or need to match production.
# For APP_NAME=HREPOLY the slug is hrepoly — adjust if you change APP_NAME.
CACHE_PREFIX=hrepoly_cache_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=hrepoly_database_

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=appsys@hrepoly.ac.zw
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=appsys@hrepoly.ac.zw
MAIL_FROM_NAME="${APP_NAME}"
MAIL_DEV_REDIRECT=jimmyneds@gmail.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Systems settings
APP_TIMEZONE='Africa/Harare'
APP_PREVIOUS_KEYS=
APP_MAINTENANCE_STORE=
APP_VERSION=

# Pagination
PAGINATION_ITEMS_PER_PAGE=10
PAGINATION_MAX_LIMIT=1000
#Unique Key Generation
APPLICATION_TRACKING_NUMBER_PREFIX=TN
APPLICATION_TRACKING_NUMBER_SUFFIX=
STUDENT_NUMBER_PREFIX=
STUDENT_NUMBER_SUFFIX=

# LOCAL API
VITE_API_BASE_URL=

# PAYMENT GATEWAY
PAYMENT_GATEWAY_NAME=
PAYMENT_GATEWAY_BASE_URL=
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SECRET=
PAYMENT_GATEWAY_RETURN_URL=
PAYMENT_GATEWAY_CANCEL_URL=
PAYMENT_GATEWAY_FAILURE_URL=
PAYMENT_GATEWAY_RESULT_URL=

# FEES PAYMENT ALERTS
BANK_PAYMENTS_ZWG_INSTITUTION_ID=
BANK_PAYMENTS_ZWG_PASSWORD=
BANK_PAYMENTS_USD_INSTITUTION_ID=
BANK_PAYMENTS_USD_PASSWORD=
BANK_PAYMENTS_INCOME_GEN_INSTITUTION_ID=
BANK_PAYMENTS_INCOME_GEN_PASSWORD=
BANK_PAYMENTS_BASE_URL=
BANK_PAYMENTS_CONNECT_TIMEOUT=10
BANK_PAYMENTS_TIMEOUT=300
BANK_PAYMENTS_RETRY_TIMES=3
BANK_PAYMENTS_RETRY_SLEEP_MS=250
BANK_PAYMENTS_QUEUE=payments

# BANK STATEMENTS
BANK_STATEMENTS_BASE_URL=
BANK_STATEMENTS_CONNECT_TIMEOUT=10
BANK_STATEMENTS_TIMEOUT=300
BANK_STATEMENTS_RETRY_TIMES=3
BANK_STATEMENTS_RETRY_SLEEP_MS=250
BANK_STATEMENTS_QUEUE=bank-statements
BANK_STATEMENTS_CHUNK_DAYS=14
BANK_STATEMENTS_DISPATCH_LIMIT=100
BANK_STATEMENTS_PROCESSING_STALE_MINUTES=45
BANK_STATEMENTS_PLAN_INSERT_CHUNK=500
BANK_STATEMENTS_PLAN_ANCHOR_START=2025-11-01
ACCOUNT_NUMBER_USD=
ACCOUNT_NUMBER_USD_PASSWORD=
ACCOUNT_NUMBER_ZWG=
ACCOUNT_NUMBER_ZWG_PASSWORD=
ACCOUNT_NUMBER_INCOME_GEN=
ACCOUNT_NUMBER_INCOME_GEN_PASSWORD=

# MAINTENANCE MODE
VITE_MAINTENANCE_MODE=false

# VERIFICATION MODE
VITE_VERIFICATION_MODE=false

# Other
AUTO_CARD_FEE=
PART_TIME_LEVY=

# Ingest Impoerters
INGEST_MAX_SHOW_ROWS=
INGEST_QUEUE_CONNECTION=
INGEST_QUEUE_NAME=
INGEST_DISK=

PURGE_ARCHIVE_RETENTION_DAYS=356